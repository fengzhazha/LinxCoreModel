                                                                         src1=%regSrc1 src1Type=0 \
                                                                         src2=%regSrc2 src2Type=0 \
                                                                         dst0=%regDst dst0Type=0
@B_IOD            ..... .. ..... ..... ... ..... ... ... .    &InstInfo  isBinst=4  src0=%regSrc0  src0Type=2 \
                                                                         src1=%regSrc1 src1Type=2 \
                                                                         src2=%regSrc2 src2Type=2 \
                                                                         dst0=%regDst dst0Type=0
@B_IOT            ...... ...... . .... ... . . ... ... ... .  &InstInfo  isBinst=4 s0R=%s0R s1R=%s1R last=%last \
                                                                         tileFunc=%tileFunc \
                                                                         src0=%uimm_15_18 src0Type=2 \
                                                                         src1=%srcTile0 src1Type=4 \
                                                                         src2=%srcTile1 src2Type=4 \
                                                                         dst0=%dstTile  dst0Type=1
@B_DIM            ............ ..... ... ..... ... ... .      &InstInfo  isBinst=4  src0=%uimm_12_14 src0Type=2 \
                                                                         src1=%regSrc0 src1Type=0 \
                                                                         src2=%uimm_7_11_and_20_31 src2Type=2 \

@MEMTEMPLATE      ..... .. ..... ..... ... ..... ... ... .    &InstInfo  isBinst=4  src0=%regSrc0 src0Type=0 src1=%regSrc1 src1Type=0 src2=%regSrc2 src2Type=0
@FPTEMPLATE       ....... ..... ..... ... ..... ... ... .     &InstInfo  isBinst=4  src0=%uimm_7_11_and_25_31_shift3 src0Type=2 src1=%regSrc0 src1Type=2 src2=%regSrc1 src2Type=2
@B_CATR           ..... . . ..... . . . . . ... ..... ... ... . &InstInfo isBinst=4 \
                                                                          src0=%rl_15 src0Type=2 \
                                                                          src1=%aq_16 src1Type=2 \
                                                                          src2=%atom_17 src2Type=2 \
                                                                          src3=%far_18 src3Type=2 \
                                                                          src4=%trap_19 src4Type=2 \
                                                                          src5=%DR src5Type=2
@B_DATR           ... .. . . ..... . . ... ... ..... ... ... .  &InstInfo isBinst=4 \
                                                                          src0=%LayOut src0Type=2 \
                                                                          src1=%RMode src1Type=2 \
                                                                          src2=%dstType_20_25 src2Type=2 \
                                                                          src3=%canon src3Type=2 \
                                                                          src4=%S src4Type=2 \
                                                                          src5=%padValue_27_28 src5Type=2 \
                                                                          src6=%CMode src6Type=2
@B_HINT_PREFETCH  ............ . .. . . ... ..... ... ... .   &InstInfo   isBinst=4 \
                                                                          src0=%Jump_Vld src0Type=2 \
                                                                          src1=%Jump_Flag src1Type=2 \
                                                                          src2=%Temprature src2Type=2 \
                                                                          src3=%PreFetch  src3Type=2
@B_HINT_TRACE     ................ . ... ..... ... ... .      &InstInfo   isBinst=4 \
                                                                          src0=%begin src0Type=2 \
                                                                          src1=%reserve src1Type=2

# Arithmetic Operation 32bit
#  block instruction encoding

MCOPY                ..... 00 ..... ..... 000 00000 011 000 1     @MEMTEMPLATE
MSET                 ..... 00 ..... ..... 001 00000 011 000 1     @MEMTEMPLATE

{
  B_IOR                ..... 00 ..... ..... 000 ..... 001 001 1     @B_IOR
  B_IOD                ..... 00 ..... ..... 001 ..... 001 001 1     @B_IOD
  B_IOT                ...... ...... . .... ... . . ... 001 001 1   @B_IOT
}

# MPAR MSEQ TMA TEPL VPAR VESQ CUBE FIXP也归纳在BSTART中, 以BlockType固定为00011区分
BSTART               ................. ... ..... 000 000 1        @BSTART
BSTART_DIRECT        ......................... 001 000 1          @BSTART_BRANCH
BSTART_COND          ......................... 010 000 1          @BSTART_BRANCH
B_TEXT               ......................... 000 001 1          @B_TEXT

B_CATR               00000 . 0 00000 . . . . . 000 00000 010 001 1 @B_CATR
B_DATR               ... .. . . ..... 0 0 ... 001 ..... 010 001 1  @B_DATR

B_DIM            ............ ........ ..... 100 001 1       @B_DIM

B_HINT_PREFETCH      ............ 0 .. . . 000 00000 011 001 1    @B_HINT_PREFETCH
B_HINT_TRACE         ................ . 001 00000 011 001 1       @B_HINT_TRACE

FENTRY               ....... ..... ..... 000 ..... 100 000 1      @FPTEMPLATE
FEXIT                ....... ..... ..... 001 ..... 100 000 1      @FPTEMPLATE
FRET_RA              ....... ..... ..... 010 ..... 100 000 1      @FPTEMPLATE
FRET_STK             ....... ..... ..... 011 ..... 100 000 1      @FPTEMPLATE

#  micro instruction encoding
ADD             ..... .. ..... ..... 000 ..... 000 010 1     @arith
SUB             ..... .. ..... ..... 001 ..... 000 010 1     @arith
AND             ..... .. ..... ..... 010 ..... 000 010 1     @arith
OR              ..... .. ..... ..... 011 ..... 000 010 1     @arith
XOR             ..... .. ..... ..... 100 ..... 000 010 1     @arith
SRL             00000 00 ..... ..... 101 ..... 000 010 1     @shift
SRA             00000 00 ..... ..... 110 ..... 000 010 1     @shift
SLL             00000 00 ..... ..... 111 ..... 000 010 1     @shift

ADDI            ............ ..... 000 ..... 001 010 1       @arith_ui
SUBI            ............ ..... 001 ..... 001 010 1       @arith_ui
ANDI            ............ ..... 010 ..... 001 010 1       @arith_si  src1=%simm_20_31
ORI             ............ ..... 011 ..... 001 010 1       @arith_si  src1=%simm_20_31
XORI            ............ ..... 100 ..... 001 010 1       @arith_si  src1=%simm_20_31
SRLI            000000 ...... ..... 101 ..... 001 010 1      @shift_i
SRAI            000000 ...... ..... 110 ..... 001 010 1      @shift_i
SLLI            000000 ...... ..... 111 ..... 001 010 1      @shift_i

# Arithmetic Operation 32bit
ADDW            ..... .. ..... ..... 000 ..... 010 010 1     @arith
SUBW            ..... .. ..... ..... 001 ..... 010 010 1     @arith
ANDW            ..... .. ..... ..... 010 ..... 010 010 1     @arith
ORW             ..... .. ..... ..... 011 ..... 010 010 1     @arith
XORW            ..... .. ..... ..... 100 ..... 010 010 1     @arith
SRLW            00000 00 ..... ..... 101 ..... 010 010 1     @shift
SRAW            00000 00 ..... ..... 110 ..... 010 010 1     @shift
SLLW            00000 00 ..... ..... 111 ..... 010 010 1     @shift

ADDIW           ............ ..... 000 ..... 011 010 1       @arith_ui
SUBIW           ............ ..... 001 ..... 011 010 1       @arith_ui
ANDIW           ............ ..... 010 ..... 011 010 1       @arith_si  src1=%simm_20_31
ORIW            ............ ..... 011 ..... 011 010 1       @arith_si  src1=%simm_20_31
XORIW           ............ ..... 100 ..... 011 010 1       @arith_si  src1=%simm_20_31
SRLIW           0000000 ..... ..... 101 ..... 011 010 1      @shift_i_w
SRAIW           0000000 ..... ..... 110 ..... 011 010 1      @shift_i_w
SLLIW           0000000 ..... ..... 111 ..... 011 010 1      @shift_i_w

# Compare Instruction
CMP_EQ          00000 .. ..... ..... 000 ..... 100 010 1     @compare
CMP_NE          00000 .. ..... ..... 001 ..... 100 010 1     @compare
CMP_AND         00000 .. ..... ..... 010 ..... 100 010 1     @compare
CMP_OR          00000 .. ..... ..... 011 ..... 100 010 1     @compare
CMP_LT          00000 .. ..... ..... 100 ..... 100 010 1     @compare
CMP_GE          00000 .. ..... ..... 101 ..... 100 010 1     @compare
CMP_LTU         00000 .. ..... ..... 110 ..... 100 010 1     @compare
CMP_GEU         00000 .. ..... ..... 111 ..... 100 010 1     @compare

CMP_EQI         ............ ..... 000 ..... 101 010 1       @arith_si  src1=%simm_20_31
CMP_NEI         ............ ..... 001 ..... 101 010 1       @arith_si  src1=%simm_20_31
CMP_ANDI        ............ ..... 010 ..... 101 010 1       @arith_si  src1=%simm_20_31
CMP_ORI         ............ ..... 011 ..... 101 010 1       @arith_si  src1=%simm_20_31
CMP_LTI         ............ ..... 100 ..... 101 010 1       @arith_si  src1=%simm_20_31
CMP_GEI         ............ ..... 101 ..... 101 010 1       @arith_si  src1=%simm_20_31
CMP_LTUI        ............ ..... 110 ..... 101 010 1       @arith_ui
CMP_GEUI        ............ ..... 111 ..... 101 010 1       @arith_ui

# SETC
SETC_EQ         00000 .. ..... ..... 000 00000 110 010 1     @setc
SETC_NE         00000 .. ..... ..... 001 00000 110 010 1     @setc
SETC_AND        00000 .. ..... ..... 010 00000 110 010 1     @setc
SETC_OR         00000 .. ..... ..... 011 00000 110 010 1     @setc
SETC_LT         00000 .. ..... ..... 100 00000 110 010 1     @setc
SETC_GE         00000 .. ..... ..... 101 00000 110 010 1     @setc
SETC_LTU        00000 .. ..... ..... 110 00000 110 010 1     @setc
SETC_GEU        00000 .. ..... ..... 111 00000 110 010 1     @setc

SETC_EQI        ............ ..... 000 ..... 111 010 1       @setc_si
SETC_NEI        ............ ..... 001 ..... 111 010 1       @setc_si
SETC_ANDI       ............ ..... 010 ..... 111 010 1       @setc_si
SETC_ORI        ............ ..... 011 ..... 111 010 1       @setc_si
SETC_LTI        ............ ..... 100 ..... 111 010 1       @setc_si
SETC_GEI        ............ ..... 101 ..... 111 010 1       @setc_si
SETC_LTUI       ............ ..... 110 ..... 111 010 1       @setc_ui
SETC_GEUI       ............ ..... 111 ..... 111 010 1       @setc_ui

# Bit Operation
BXS             ...... ...... ..... 000 ..... 110 011 1      @bo
BXU             ...... ...... ..... 001 ..... 110 011 1      @bo
BIC             ...... ...... ..... 010 ..... 110 011 1      @bo
BIS             ...... ...... ..... 011 ..... 110 011 1      @bo

# Multi-Cycle ALU
MUL             00000 00 ..... ..... 000 ..... 100 011 1     @shift
MULU            00000 00 ..... ..... 001 ..... 100 011 1     @shift
MULW            00000 00 ..... ..... 010 ..... 100 011 1     @shift
MULUW           00000 00 ..... ..... 011 ..... 100 011 1     @shift
MADD            ..... 00 ..... ..... 110 ..... 100 011 1     @MADD
MADDW           ..... 00 ..... ..... 111 ..... 100 011 1     @MADD

# Constant
{
  SETRET          .................... 01010 000 011 1         @SETRET
  ADDTPC          .................... ..... 000 011 1         @constant
}
LUI             .................... ..... 001 011 1         @constant

# Load Register Offset
