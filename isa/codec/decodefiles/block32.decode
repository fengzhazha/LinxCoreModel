# Argument sets:

&InstInfo           srcType  dstType \
                    aq  rl  far atom trap canon dr \
                    srcRType \
                    srcRIndex \
                    src0 src0Type src0Shamt \
                    src1 src1Type src1Shamt \
                    src2 src2Type src2Shamt \
                    src3 src3Type \
                    src4 src4Type \
                    src5 src5Type \
                    src6 src6Type \
                    src7 src7Type \
                    src8 src8Type \
                    src9 src9Type \
                    dst0 dst0Type \
                    isBinst last \
                    s0R  s1R  tileFunc

# Formats linx:


@arith          ..... .. ..... ..... ... ..... ... ... .    &InstInfo   src0=%SrcL src0Type=0 \
                                                                        src1=%SrcR src1Type=0 \
                                                                        srcRType=%SrcRType \
                                                                        src2=%shamt_27_31 src2Type=2 \
                                                                        dst0=%RegDst dst0Type=0

@shift          ..... .. ..... ..... ... ..... ... ... .    &InstInfo   src0=%SrcL src0Type=0 \
                                                                        src1=%SrcR src1Type=0 \
                                                                        dst0=%RegDst dst0Type=0

@arith_ui       ............ ..... ... ..... ... ... .      &InstInfo   src0=%SrcL src0Type=0 \
                                                                        src1=%uimm_20_31 src1Type=2 \
                                                                        dst0=%RegDst dst0Type=0

@arith_si       ............ ..... ... ..... ... ... .      &InstInfo   src0=%SrcL src0Type=0 \
                                                                        src1Type=1 \
                                                                        dst0=%RegDst dst0Type=0

@shift_i        ...... ...... ..... ... ..... ... ... .     &InstInfo   src0=%SrcL src0Type=0 \
                                                                        src1=%shamt_20_25 src1Type=2 \
                                                                        dst0=%RegDst dst0Type=0

@shift_i_w      ....... ..... ..... ... ..... ... ... .     &InstInfo   src0=%SrcL src0Type=0 \
                                                                        src1=%shamt_20_24 src1Type=2 \
                                                                        dst0=%RegDst dst0Type=0

@compare        ..... .. ..... ..... ... ..... ... ... .    &InstInfo   src0=%SrcL src0Type=0 \
                                                                        src1=%SrcR  src1Type=0 \
                                                                        srcRType=%SrcRType \
                                                                        dst0=%RegDst dst0Type=0

@setc           ..... .. ..... ..... ... ..... ... ... .    &InstInfo   src0=%SrcL src0Type=0 \
                                                                        src1=%SrcR src1Type=0 \
                                                                        srcRType=%SrcRType

@setc_si        ............ ..... ... ..... ... ... .      &InstInfo   src0=%shamt_7_11 src0Type=2 \
                                                                        src1=%SrcL src1Type=0 \
                                                                        src2=%simm_20_31 src2Type=1

@setc_ui        ............ ..... ... ..... ... ... .      &InstInfo   src0=%shamt_7_11 src0Type=2 \
                                                                        src1=%SrcL src1Type=0 \
                                                                        src2=%uimm_20_31 src2Type=2

@bo             ...... ...... ..... ... ..... ... ... .     &InstInfo   src0=%SrcL src0Type=0 \
                                                                        src1=%imms src1Type=2 \
                                                                        src2=%imml_inc src2Type=2 \
                                                                        dst0=%RegDst dst0Type=0

@MADD           ..... .. ..... ..... ... ..... ... ... .    &InstInfo   src0=%SrcL src0Type=0 \
                                                                        src1=%SrcR src1Type=0 \
                                                                        src2=%SrcD src2Type=0 \
                                                                        dst0=%RegDst dst0Type=0

@constant       .................... ..... ... ... .        &InstInfo   src0=%simm_12_31_shift12 src0Type=1 \
                                                                        dst0=%RegDst dst0Type=0

