                                                                        src1=%SrcR src1Type=0 \
                                                                        dst0=%RegDst dst0Type=0

@fmax_fmin      ..... .. ..... ..... ... ..... ... ... .    &InstInfo   srcType=%SrcType \
                                                                        src0=%SrcL src0Type=0 \
                                                                        src1=%SrcR src1Type=0 \
                                                                        dst0=%RegDst dst0Type=0

@exec_ctrl      .... .... .... ..... ... ..... ... ... .    &InstInfo   src0=%SrcL src0Type=0

@FENCE_D        .... .... .... ..... ... ..... ... ... .    &InstInfo   src0=%SUCC_IMM src0Type=2 \
                                                                        src1=%PRED_IMM src1Type=2 \
                                                                        src2=%mode_29  src2Type=2

@FENCE_I        .... .... .... ..... ... ..... ... ... .    &InstInfo

@acrc           .... .... .... ..... ... ..... ... ... .    &InstInfo   src0=%request_type src0Type=2

@acre           .... .... .... ..... ... ..... ... ... .    &InstInfo   src0=%request_type src0Type=2

@lr             .... . . . ..... ..... ... ..... ... ... .  &InstInfo   aq=%aq rl=%rl far=%far \
                                                                        src0=%SrcL src0Type=0 \
                                                                        src1=0 src1Type=0 \
                                                                        dst0=%RegDst dst0Type=0

@sc             .... . . . ..... ..... ... ..... ... ... .  &InstInfo   aq=%aq rl=%rl far=%far \
                                                                        src0=%SrcL src0Type=0 \
                                                                        src1=%SrcR src1Type=0 \
                                                                        dst0=%RegDst dst0Type=0

@sc_2           .... . . . ..... ..... ... ..... ... ... .  &InstInfo   src0=%SrcL src0Type=0 \
                                                                        dst0=%SrcR dst0Type=0
# 这里用dst来接收SrcR，是为了适配AtomicAaccelssMemory接口

@atomic_ld      .... . . . ..... ..... ... ..... ... ... .  &InstInfo   aq=%aq rl=%rl far=%far \
                                                                        src0=%SrcL src0Type=0 \
                                                                        src1=%SrcR src1Type=0 \
                                                                        dst0=%RegDst dst0Type=0

@atomic_st      .... . . . ..... ..... ... ..... ... ... .  &InstInfo   aq=0 rl=%rl far=%far \
                                                                        src0=%SrcL src0Type=0 \
                                                                        src1=%SrcR src1Type=0 \
                                                                        dst0=0 dst0Type=0

@CVT            ..... .. ..... ..... ... ..... ... ... .    &InstInfo   dstType=%DstType_cvt \
                                                                        srcType=%SrcType_cvt \
                                                                        src0=%SrcL src0Type=0 \
                                                                        dst0=%RegDst dst0Type=0

@LoadSymbol     ................. ... ..... ... ... .       &InstInfo   src0=%simm_15_31 src0Type=1 \
                                                                        dst0=%RegDst dst0Type=0

@StoreSymbol    ............ ..... ... ..... ... ... .      &InstInfo   src0=%SrcL src0Type=0 \
                                                                        src1=%simm_7_11_and_20_31 src1Type=1

@branch         ....... ..... ..... ... ..... ... ... .     &InstInfo   src0=%SrcL src0Type=0 \
                                                                        src1=%SrcR src1Type=0 \
                                                                        src2=%simm_7_11_and_25_31_shift1 src2Type=1

@JR             ....... ..... ..... ... ..... ... ... .     &InstInfo   src0=%SrcL src0Type=0 \
                                                                        src1=0 src1Type=0 \
                                                                        src2=%simm_7_11_and_25_31_shift1 src2Type=1

@J              ................. ... ..... ... ... .       &InstInfo   src0=%simm_7_11_and_15_31_shift1 src0Type=1

@Cache_SRC      .... .... .... ..... ... ..... ... ... .    &InstInfo   src0=%SrcL

@Cache_NOSRC    .... .... .... ..... ... ..... ... ... .    &InstInfo

@BSTART           ................. ... ..... ... ... .       &InstInfo  isBinst=4  src0=%BlockType_7_11 src0Type=2 \
                                                                         src1=%BrType_12_14 src1Type=2 \
                                                                         src2=%simm_15_31_shift1 src2Type=1
@BSTART_BRANCH    ......................... ... ... .         &InstInfo  isBinst=4  src0=%simm_7_31_shift1 src0Type=1
@B_TEXT           ......................... ... ... .         &InstInfo  isBinst=4  src0=%simm_7_31_shift1 src0Type=1
