                                                                        src2=%SrcR src2Type=0 \
                                                                        srcRType=%SrcRType \
                                                                        srcRIndex=2


@store_imm      ....... ..... ..... ... ..... ... ... .     &InstInfo   src0=%SrcL src0Type=0 \
                                                                        src1=%SrcR src1Type=0 \
                                                                        src2Type=1

@multi          ....... ..... ..... ... ..... ... ... .     &InstInfo   src0=%SrcL src0Type=0 \
                                                                        src1=%SrcR src1Type=0 \
                                                                        dst0=%RegDst dst0Type=0

